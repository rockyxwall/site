---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  tags: string[];
  github?: string;
  live?: string;
  slug: string;
}

const { title, description, tags, github, live, slug } = Astro.props;
---

<div class="group relative bg-[var(--bg-card)] border border-[var(--border)] rounded-[var(--radius)] p-6 transition-all duration-[var(--transition)] hover:-translate-y-0.5 hover:border-[var(--border-active)]">
  <div class="absolute top-6 right-6 flex gap-3 z-10">
    {github && (
      <a href={github} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-accent transition-colors" title="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
    )}
    {live && (
      <a href={live} target="_blank" rel="noopener noreferrer" class="text-[var(--text-muted)] hover:text-accent transition-colors" title="Live Demo">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    )}
  </div>

  <a href={`/projects/${slug}`} class="block">
    <h3 class="text-xl font-medium mb-3 group-hover:text-accent transition-colors pr-12">{title}</h3>
    <p class="text-[var(--text-secondary)] text-sm mb-6 line-clamp-2">{description}</p>
    
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => <Tag name={tag} />)}
    </div>
  </a>
</div>
