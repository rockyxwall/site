---
const navItems = [
  { label: 'Blog', href: '/blog' },
  { label: 'Projects', href: '/projects' },
  { label: 'YouTube', href: '/youtube' },
];

const { pathname } = Astro.url;
const isActive = (path: string) => pathname.startsWith(path);
---

<nav class="sticky top-0 z-50 bg-[var(--bg-primary)]/80 backdrop-blur-md border-b border-[var(--border)]">
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-accent tracking-tighter">
      RW
    </a>

    <div class="flex items-center gap-6">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`relative py-1 text-sm font-medium transition-colors hover:text-white ${isActive(item.href) ? 'text-accent' : 'text-[var(--text-secondary)]'}`}
        >
          {item.label}
          {isActive(item.href) && (
            <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 bg-accent rounded-full" />
          )}
        </a>
      ))}
      <a 
        href="https://github.com" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-sm font-medium text-[var(--text-secondary)] hover:text-white flex items-center gap-1"
      >
        GitHub <span class="text-[10px]">↗</span>
      </a>
    </div>
  </div>
</nav>
